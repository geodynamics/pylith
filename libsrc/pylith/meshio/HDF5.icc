template <> inline hid_t
pylith::meshio::HDF5::_h5NativeType<float>() {
    return H5T_NATIVE_FLOAT;
}


template <> inline hid_t
pylith::meshio::HDF5::_h5NativeType<double>() {
    return H5T_NATIVE_DOUBLE;
}


template <> inline hid_t
pylith::meshio::HDF5::_h5NativeType<int>() {
    return H5T_NATIVE_INT;
}


template <> inline hid_t
pylith::meshio::HDF5::_h5NativeType<long>() {
    return H5T_NATIVE_LONG;
}


